# ===================================
# Configuration Base de Données PostgreSQL
# ===================================
DB_NAME=Activities
DB_USER=api_client
DB_PASSWORD=ActApi24*
DB_PORT=5432
# ===================================
# Configuration Application Spring Boot
# ===================================
APP_PORT=8080
# ===================================
# Configuration JPA/Hibernate
