# Options: create, create-drop, update, validate, none
SPRING_JPA_HIBERNATE_DDL_AUTO=update
# ===================================
# Configuration Logs
# ===================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ACTIVITIES_COM_BACKEND=DEBUG
